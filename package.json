{
  "name": "jobshour-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev -p 3002 -H 0.0.0.0",
    "build": "cross-env NEXT_EXPORT= next build",
    "build:safe": "cross-env NODE_OPTIONS=--max-old-space-size=8192 next build",
    "build:android": "node scripts/build-android-static.mjs",
    "start": "next start -p 3001",
    "lint": "next lint --max-warnings 99999",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze": "cross-env ANALYZE=true next build"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.2",
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/cli": "^7.6.2",
    "@capacitor/core": "^7.6.2",
    "firebase": "^12.9.0",
    "framer-motion": "^12.34.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.1.0",
    "laravel-echo": "^2.3.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.574.0",
    "next": "^15.5.15",
    "pusher-js": "^8.4.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.5.15",
    "@types/leaflet": "^1.9.8",
