    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.17",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^3.2.0"
  }
