# Copia a `.env.local` para desarrollo. No subas secretos de producción.

# API pública (se incrusta en build si usas NEXT_PUBLIC_*)
NEXT_PUBLIC_API_URL=http://localhost:8095/api
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=us2

# Analytics: POST de eventos (misma app: ruta API Routes)
NEXT_PUBLIC_ANALYTICS_INGEST=/api/jh-analytics

# Solo servidor Next: reenvío opcional al backend Laravel
# ANALYTICS_FORWARD_URL=https://tu-dominio.com/api/v1/analytics/events
# ANALYTICS_FORWARD_SECRET=
